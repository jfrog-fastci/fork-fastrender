// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`InstMetaPanel > renders instruction metadata 1`] = `"<div class="InstMetaPanel"><header><strong>Instruction metadata</strong><span class="inst-summary"> • Call → %1</span></header><div class="toggles"><label class="toggle"><input type="checkbox" checked=""/>Effects</label><label class="toggle"><input type="checkbox" checked=""/>Ownership/escape</label><label class="toggle"><input type="checkbox" checked=""/>Range/nullability/encoding</label><label class="toggle"><input type="checkbox" checked=""/>Typed IDs</label><label class="toggle"><input type="checkbox"/>Raw</label></div><div class="sections"><section><h2>Effects</h2><ul><li>unknown: <code>true</code></li><li>reads: <code>Heap</code></li><li>writes: <code>Foreign(1)</code></li></ul></section><section><h2>Ownership / escape</h2><ul><li>ownership: <code>Owned</code></li><li>arg use modes: <code>0:Borrow, 1:Consume</code></li><li>in-place hint: <code>n/a</code></li><li>result escape: <code>return_escape</code></li><li>purity: <code>Impure</code></li><li>callee purity: <code>Impure</code></li></ul></section><section><h2>Value facts</h2><ul><li>range: <code>[0, 10]</code></li><li>nullability: <code>null=false, undef=false, other=true, bottom=false</code></li><li>encoding: <code>utf8</code></li><li>excludesNullish: <code>true</code></li></ul></section><section><h2>Typed layouts</h2><ul><li>typeId: <code>123</code></li><li>nativeLayout: <code>0x00000000000000000000000000000000</code></li><li>typeSummary: <code>Number</code></li><li>hirExpr: <code>7</code></li></ul></section></div></div>"`;
