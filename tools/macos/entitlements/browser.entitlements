<?xml version="1.0" encoding="UTF-8"?>
<!--
  FastRender (macOS) — browser / UI process entitlements

  This file is intentionally minimal: the "browser" process is the trusted
  coordinator in the multiprocess architecture and is expected to retain broad
  OS access (networking, file access, windowing, persistent storage, etc.).

  In the first `.app` bundling iteration we expect the browser process to be
  *not* App-Sandboxed. Passing this file to `codesign --entitlements` should
  result in a signed binary with no App Sandbox entitlement.

  TODO(macos-app):
  - Re-evaluate whether the browser process should also be sandboxed (e.g. for
    Mac App Store distribution). If so, this file will need to enable
    `com.apple.security.app-sandbox` and explicitly enumerate the minimum
    required entitlements (network, files, user-selected access, etc.).
  - If/when we ship with Hardened Runtime + JIT-enabled JavaScript, we may need
    to add hardened-runtime-related entitlements here instead of (or in addition
    to) sandboxing-related keys.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
  </dict>
</plist>

